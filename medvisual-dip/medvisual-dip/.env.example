# MedVisual DIP -- Ortam Degiskenleri
# Bu dosyayi .env olarak kopyala ve doldur:
#   cp .env.example .env

# Google Gemini API (istege bagli -- yoksa AI zenginlestirme devre disi)
# Google AI Studio: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=buraya-google-api-key-yaz

# Kullanilacak Gemini modeli (varsayilan: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash

# Poppler PATH (Windows'ta pdftotext.exe dizini)
# POPPLER_PATH=C:\Users\...\poppler\bin
