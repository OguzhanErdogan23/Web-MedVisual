# Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# service_role (legacy) VEYA sb_secret_... (yeni anahtar sistemi) — GIZLI tutun,
# yalnizca bu backend'de kullanilir, istemcilere asla verilmez.
SUPABASE_SERVICE_ROLE_KEY=

# Legacy projelerde: Settings -> API -> JWT Settings -> JWT Secret.
# Yeni projelerde (asimetrik imza) BOS birakin — JWKS ile dogrulanir.
SUPABASE_JWT_SECRET=

# DIP motoru (medvisual-dip, ayni makinede calisir)
DIP_ENGINE_URL=http://localhost:5000

# Secilen kart gorsellerinin yuklendigi bucket
STORAGE_BUCKET=card-images

# Gemini zenginlestirme (OPSIYONEL) — bos birakilirsa sistem tamamen
# offline (kendi algoritmamizla) calisir. DIP ile ayni GOOGLE_API_KEY.
# GEMINI_MODELS: sirayla denenecek modeller (biri kota/hata -> sonraki).
GOOGLE_API_KEY=
GEMINI_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite,gemini-2.0-flash-lite,gemini-2.0-flash
